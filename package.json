{
  "name": "beervid-cli",
  "version": "0.1.12",
  "description": "Zero-dependency CLI for the Beervid Open API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myducky/BeervidCli.git"
  },
  "homepage": "https://github.com/myducky/BeervidCli#readme",
  "bugs": {
    "url": "https://github.com/myducky/BeervidCli/issues"
  },
  "keywords": [
    "beervid",
    "cli",
    "tiktok",
    "video",
    "open-api"
  ],
  "bin": {
    "beervid": "bin/beervid.js",
    "beervid-cli": "bin/beervid.js"
  },
  "type": "commonjs",
  "files": [
    "bin",
    "examples",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "preferGlobal": true,
  "scripts": {
    "start": "node ./bin/beervid.js",
    "test": "node --test \"./test/**/*.test.js\"",
    "test:unit": "node --test \"./test/unit/**/*.test.js\"",
    "test:commands": "node --test \"./test/commands/**/*.test.js\"",
    "test:cli": "node --test \"./test/cli/**/*.test.js\"",
    "test:smoke": "node ./bin/beervid.js --help",
    "check:syntax": "node --check ./bin/beervid.js && find ./src ./test -name '*.js' -print0 | xargs -0 -n 1 node --check",
    "pack:check": "npm --cache ./.npm-cache pack --dry-run"
  }
}
